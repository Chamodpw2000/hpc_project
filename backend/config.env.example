# Score Analyzer Backend Configuration
# Copy this file to config.env and update with your MongoDB Atlas credentials

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/score_analyzer?retryWrites=true&w=majority

# Database name
DB_NAME=score_analyzer

# Server port
PORT=8090
